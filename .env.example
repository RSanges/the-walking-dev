# === The Walking Dev: secrets (copy to .env, never commit) ===

# Telegram (create a bot via @BotFather)
TELEGRAM_BOT_TOKEN=
# Your own chat id (via @userinfobot). Required for the bot to message you, and
# it restricts the bot to ONLY answer you — leave empty only for first setup.
TELEGRAM_CHAT_ID=

# ScriptWriter fallback (only if writer.backend = "api" in config.yaml)
ANTHROPIC_API_KEY=

# --- Classic web hosting over FTPS/SFTP (hosting.backend = ftp) ---
FTP_USER=
FTP_PASSWORD=
# Optional overrides (otherwise taken from config.yaml hosting.ftp):
# FTP_HOST=
# FTP_PUBLIC_BASE_URL=

# --- Object storage for the podcast feed ---
# Used when hosting.backend is ovh | r2 | s3 | scaleway | minio.
# Generic S3 credentials (work for every S3-compatible provider, incl. OVHcloud):
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional overrides (otherwise taken from config.yaml hosting.<backend>):
# S3_ENDPOINT_URL=
# S3_REGION=
# S3_BUCKET=walkingdev
# S3_PUBLIC_BASE_URL=

# Cloudflare R2 ONLY (hosting.backend = r2): also set the account id.
R2_ACCOUNT_ID=

# Supabase (only if state.backend = "supabase")
SUPABASE_URL=
SUPABASE_KEY=
