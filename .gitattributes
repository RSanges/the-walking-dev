# Normalize line endings: LF in the repo for text, CRLF for Windows scripts.
* text=auto eol=lf

*.py   text eol=lf
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf

# Windows-only helper scripts keep CRLF
*.ps1  text eol=crlf
*.vbs  text eol=crlf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.wav  binary
*.mp3  binary
*.ico  binary
